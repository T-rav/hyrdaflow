# HydraFlow Environment Variables
# Copy to .env and customize as needed:  cp .env.sample .env
#
# Most users only need the first two sections (identity + tool/model selection).
# Everything else has sensible defaults.

# ──────────────────────────────────────────────────────────────────────────────
# Identity & repo
# ──────────────────────────────────────────────────────────────────────────────

# GitHub repo (auto-detected from git remote if unset)
# HYDRAFLOW_GITHUB_REPO=owner/repo

# Ops user identity (optional — falls back to local git/gh auth)
# HYDRAFLOW_GH_TOKEN=ghp_...
# HYDRAFLOW_GIT_USER_NAME=HydraFlow-Ops
# HYDRAFLOW_GIT_USER_EMAIL=ops@example.com

# ──────────────────────────────────────────────────────────────────────────────
# Tool & model selection
# ──────────────────────────────────────────────────────────────────────────────

# Grouped defaults — set these to configure all pipeline stages at once.
# Per-stage overrides below take precedence.
# HYDRAFLOW_SYSTEM_TOOL=claude          # inherit | claude | codex | pi
# HYDRAFLOW_SYSTEM_MODEL=opus           # cascades to model, review_model, planner_model, ac_model, etc.
# HYDRAFLOW_BACKGROUND_TOOL=claude      # cascades to triage, transcript_summary, memory_compaction, report_issue
# HYDRAFLOW_BACKGROUND_MODEL=haiku

# Per-stage tool overrides (default: claude)
# HYDRAFLOW_IMPLEMENTATION_TOOL=claude
# HYDRAFLOW_REVIEW_TOOL=claude
# HYDRAFLOW_PLANNER_TOOL=claude
# HYDRAFLOW_TRIAGE_TOOL=claude
# HYDRAFLOW_AC_TOOL=claude
# HYDRAFLOW_VERIFICATION_JUDGE_TOOL=claude
# HYDRAFLOW_SUBSKILL_TOOL=claude
# HYDRAFLOW_DEBUG_TOOL=claude
# HYDRAFLOW_REPORT_ISSUE_TOOL=claude
# HYDRAFLOW_MEMORY_COMPACTION_TOOL=claude
# HYDRAFLOW_TRANSCRIPT_SUMMARY_TOOL=claude

# Per-stage model overrides
# HYDRAFLOW_TRIAGE_MODEL=haiku
# HYDRAFLOW_SUBSKILL_MODEL=haiku
# HYDRAFLOW_DEBUG_MODEL=opus
# HYDRAFLOW_MEMORY_COMPACTION_MODEL=haiku
# HYDRAFLOW_TRANSCRIPT_SUMMARY_MODEL=haiku
# HYDRAFLOW_REPORT_ISSUE_MODEL=opus
# HYDRAFLOW_ADR_REVIEW_MODEL=sonnet
# HYDRAFLOW_AC_MODEL is set via HYDRAFLOW_SYSTEM_MODEL cascade (no direct env var)

# ──────────────────────────────────────────────────────────────────────────────
# Server & dashboard
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_DASHBOARD_HOST=127.0.0.1   # set 0.0.0.0 to expose beyond localhost
# HYDRAFLOW_DASHBOARD_PORT=5555
# HYDRAFLOW_DRY_RUN=false
# HYDRAFLOW_VERBOSE_LOGS=false
# HYDRAFLOW_LOG_FILE=                   # path to log file (optional)
# HYDRAFLOW_CONFIG_FILE=                # path to runtime config JSON (optional)
# HYDRAFLOW_HOME=                       # e.g. ~/.hydraflow/owner-repo

# ──────────────────────────────────────────────────────────────────────────────
# Execution mode
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_EXECUTION_MODE=host         # host | docker
# HYDRAFLOW_DOCKER_IMAGE=ghcr.io/t-rav/hydraflow-agent:latest
# HYDRAFLOW_DOCKER_NETWORK=
# HYDRAFLOW_DOCKER_NETWORK_MODE=bridge  # bridge | host | none
# HYDRAFLOW_DOCKER_CPU_LIMIT=2.0
# HYDRAFLOW_DOCKER_MEMORY_LIMIT=4g
# HYDRAFLOW_DOCKER_TMP_SIZE=1g
# HYDRAFLOW_DOCKER_PIDS_LIMIT=256       # 16–4096
# HYDRAFLOW_DOCKER_SPAWN_DELAY=2.0
# HYDRAFLOW_DOCKER_READ_ONLY_ROOT=true
# HYDRAFLOW_DOCKER_NO_NEW_PRIVILEGES=true

# ──────────────────────────────────────────────────────────────────────────────
# Labels (defaults shown — override to use custom names)
# ──────────────────────────────────────────────────────────────────────────────

# Pipeline lifecycle
HYDRAFLOW_LABEL_FIND=hydraflow-find
HYDRAFLOW_LABEL_PLAN=hydraflow-plan
HYDRAFLOW_LABEL_READY=hydraflow-ready
HYDRAFLOW_LABEL_REVIEW=hydraflow-review
HYDRAFLOW_LABEL_HITL=hydraflow-hitl
HYDRAFLOW_LABEL_HITL_ACTIVE=hydraflow-hitl-active
HYDRAFLOW_LABEL_HITL_AUTOFIX=hydraflow-hitl-autofix
HYDRAFLOW_LABEL_FIXED=hydraflow-fixed

# Auxiliary
# HYDRAFLOW_LABEL_EPIC=hydraflow-epic
# HYDRAFLOW_LABEL_EPIC_CHILD=hydraflow-epic-child
# HYDRAFLOW_LABEL_VERIFY=hydraflow-verify
# HYDRAFLOW_LABEL_IMPROVE=hydraflow-improve
# HYDRAFLOW_LABEL_MEMORY=hydraflow-memory
# HYDRAFLOW_LABEL_TRANSCRIPT=hydraflow-transcript
# HYDRAFLOW_LABEL_MANIFEST=hydraflow-manifest
# HYDRAFLOW_LABEL_METRICS=hydraflow-metrics
# HYDRAFLOW_LABEL_DUP=hydraflow-dup

# ──────────────────────────────────────────────────────────────────────────────
# Polling & background loop intervals (seconds)
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_DATA_POLL_INTERVAL=300
# HYDRAFLOW_MEMORY_SYNC_INTERVAL=3600
# HYDRAFLOW_METRICS_SYNC_INTERVAL=7200
# HYDRAFLOW_MANIFEST_REFRESH_INTERVAL=3600
# HYDRAFLOW_PR_UNSTICK_INTERVAL=3600
# HYDRAFLOW_REPORT_ISSUE_INTERVAL=30
# HYDRAFLOW_EPIC_MONITOR_INTERVAL=1800
# HYDRAFLOW_EPIC_SWEEP_INTERVAL=3600
# HYDRAFLOW_VERIFY_MONITOR_INTERVAL=3600
# HYDRAFLOW_WORKTREE_GC_INTERVAL=1800
# HYDRAFLOW_RUNS_GC_INTERVAL=3600
# HYDRAFLOW_ADR_REVIEW_INTERVAL=86400

# ──────────────────────────────────────────────────────────────────────────────
# Timeouts (seconds)
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_AGENT_TIMEOUT=3600
# HYDRAFLOW_QUALITY_TIMEOUT=3600
# HYDRAFLOW_GIT_COMMAND_TIMEOUT=30
# HYDRAFLOW_SUMMARIZER_TIMEOUT=120
# HYDRAFLOW_TRANSCRIPT_SUMMARY_TIMEOUT=120
# HYDRAFLOW_MEMORY_COMPACTION_TIMEOUT=60

# ──────────────────────────────────────────────────────────────────────────────
# Retry & attempt limits
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_MAX_ISSUE_ATTEMPTS=3
# HYDRAFLOW_MAX_REVIEW_FIX_ATTEMPTS=2
# HYDRAFLOW_MAX_PRE_QUALITY_REVIEW_ATTEMPTS=3
# HYDRAFLOW_MAX_DIFF_SANITY_ATTEMPTS=1
# HYDRAFLOW_MAX_TEST_ADEQUACY_ATTEMPTS=1
# HYDRAFLOW_MAX_MERGE_CONFLICT_FIX_ATTEMPTS=3
# HYDRAFLOW_MAX_CI_TIMEOUT_FIX_ATTEMPTS=2
# HYDRAFLOW_MAX_SUBSKILL_ATTEMPTS=0
# HYDRAFLOW_MAX_DEBUG_ATTEMPTS=1
# HYDRAFLOW_GH_MAX_RETRIES=3

# ──────────────────────────────────────────────────────────────────────────────
# Prompt budget limits (characters)
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_MAX_ISSUE_BODY_CHARS=10000
# HYDRAFLOW_MAX_REVIEW_DIFF_CHARS=15000
# HYDRAFLOW_MAX_MANIFEST_PROMPT_CHARS=2000
# HYDRAFLOW_MAX_TRANSCRIPT_SUMMARY_CHARS=50000
# HYDRAFLOW_MAX_RUNTIME_LOG_CHARS=8000
# HYDRAFLOW_MAX_CI_LOG_CHARS=12000
# HYDRAFLOW_MAX_CODE_SCANNING_CHARS=6000
# HYDRAFLOW_MAX_DISCUSSION_COMMENT_CHARS
# HYDRAFLOW_MAX_COMMON_FEEDBACK_CHARS
# HYDRAFLOW_MAX_IMPL_PLAN_CHARS
# HYDRAFLOW_MAX_REVIEW_FEEDBACK_CHARS
# HYDRAFLOW_MAX_PLANNER_COMMENT_CHARS
# HYDRAFLOW_MAX_PLANNER_LINE_CHARS
# HYDRAFLOW_MAX_PLANNER_FAILED_PLAN_CHARS
# HYDRAFLOW_MAX_HITL_CORRECTION_CHARS
# HYDRAFLOW_MAX_HITL_CAUSE_CHARS
# HYDRAFLOW_MAX_CI_LOG_PROMPT_CHARS
# HYDRAFLOW_MAX_UNSTICKER_CAUSE_CHARS
# HYDRAFLOW_MAX_VERIFICATION_INSTRUCTIONS_CHARS
# HYDRAFLOW_MAX_TROUBLESHOOTING_PROMPT_CHARS
# HYDRAFLOW_ERROR_OUTPUT_MAX_CHARS=3000

# ──────────────────────────────────────────────────────────────────────────────
# Feature flags
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_TRANSCRIPT_SUMMARIZATION_ENABLED=true
# HYDRAFLOW_DEBUG_ESCALATION_ENABLED=true
# HYDRAFLOW_ENABLE_FRESH_BRANCH_REBUILD=true
# HYDRAFLOW_COLLABORATOR_CHECK_ENABLED=true
# HYDRAFLOW_MEMORY_AUTO_APPROVE=false
# HYDRAFLOW_UNSTICK_AUTO_MERGE=true
# HYDRAFLOW_UNSTICK_ALL_CAUSES=true

# ──────────────────────────────────────────────────────────────────────────────
# Visual validation
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_VISUAL_VALIDATION_ENABLED=true
# HYDRAFLOW_VISUAL_GATE_ENABLED=false
# HYDRAFLOW_VISUAL_GATE_BYPASS=false
# HYDRAFLOW_VISUAL_DIFF_THRESHOLD=0.01
# HYDRAFLOW_VISUAL_WARN_THRESHOLD=0.05
# HYDRAFLOW_VISUAL_FAIL_THRESHOLD=0.15
# HYDRAFLOW_VISUAL_MAX_RETRIES=2
# HYDRAFLOW_VISUAL_RETRY_DELAY=2.0
# HYDRAFLOW_VISUAL_MAX_SCREENS
# HYDRAFLOW_VISUAL_PER_SCREEN_BUDGET_BYTES
# HYDRAFLOW_SCREENSHOT_REDACTION_ENABLED=true
# HYDRAFLOW_SCREENSHOT_GIST_PUBLIC=false

# ──────────────────────────────────────────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────────────────────────────────────────

# HYDRAFLOW_GH_API_CONCURRENCY=5
# HYDRAFLOW_MAX_SESSIONS_PER_REPO=10
# HYDRAFLOW_COLLABORATOR_CACHE_TTL=600
# HYDRAFLOW_ARTIFACT_RETENTION_DAYS=30
# HYDRAFLOW_ARTIFACT_MAX_SIZE_MB=500
# HYDRAFLOW_PR_UNSTICK_BATCH_SIZE=10
# HYDRAFLOW_STALE_REPORT_THRESHOLD_HOURS=6
# HYDRAFLOW_MIN_PLAN_WORDS=200
# HYDRAFLOW_MIN_REVIEW_FINDINGS=3
# HYDRAFLOW_LITE_PLAN_LABELS=bug,typo,docs
# HYDRAFLOW_TEST_COMMAND=make test
# HYDRAFLOW_HARNESS_INSIGHT_WINDOW=20
# HYDRAFLOW_HARNESS_PATTERN_THRESHOLD=3
# HYDRAFLOW_ADR_REVIEW_APPROVAL_THRESHOLD=2
# HYDRAFLOW_ADR_REVIEW_MAX_ROUNDS=3
# HYDRAFLOW_CHANGELOG_FILE=
# HYDRAFLOW_RELEASE_TAG_PREFIX=v
# HYDRAFLOW_RELEASE_VERSION_SOURCE=tag     # tag | changelog
# HYDRAFLOW_EPIC_MERGE_STRATEGY=squash     # squash | merge | rebase
# HYDRAFLOW_REPOS_WORKSPACE_DIR=~/.hydra/repos

# ──────────────────────────────────────────────────────────────────────────────
# Provider API keys (for Docker execution or non-default providers)
# ──────────────────────────────────────────────────────────────────────────────

# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=               # from `claude setup-token`
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# TOGETHER_API_KEY=
# GROQ_API_KEY=
