#!/usr/bin/env bash
# Pre-commit hook: centralized lint gate via Makefile.

set -euo pipefail

# ── Guard: CLAUDE.md must never be deleted or have content removed ──
REPO_ROOT="$(git rev-parse --show-toplevel)"

# Block deletion of CLAUDE.md
DELETED_CLAUDE=$(git diff --cached --name-only --diff-filter=D -- 'CLAUDE.md' || true)
if [ -n "$DELETED_CLAUDE" ]; then
    echo "pre-commit: BLOCKED — CLAUDE.md cannot be deleted." >&2
    exit 1
fi

# Block net content removal from CLAUDE.md (overwrites / truncation)
STAGED_CLAUDE=$(git diff --cached --name-only --diff-filter=M -- 'CLAUDE.md' || true)
if [ -n "$STAGED_CLAUDE" ]; then
    LINES_ADDED=$(git diff --cached --numstat -- 'CLAUDE.md' | awk '{print $1}')
    LINES_REMOVED=$(git diff --cached --numstat -- 'CLAUDE.md' | awk '{print $2}')
    if [ "${LINES_REMOVED:-0}" -gt "${LINES_ADDED:-0}" ]; then
        echo "pre-commit: BLOCKED — CLAUDE.md has net content removal (added=$LINES_ADDED, removed=$LINES_REMOVED)." >&2
        echo "  CLAUDE.md content must be preserved. You may add or modify sections, but not shrink the file." >&2
        exit 1
    fi
fi

# Detect Python changes (existing) AND arch source changes (new).
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' || true)
STAGED_ARCH=$(git diff --cached --name-only --diff-filter=ACM \
    -- 'docs/arch/*.likec4' \
       'docs/arch/functional_areas.yml' \
       'docs/arch/source/*' \
       'src/*.py' || true)
STAGED_TESTS=$(git diff --cached --name-only --diff-filter=ACM -- 'tests/test_*.py' || true)

# Short-circuit only when no relevant trigger fires.
if [ -z "$STAGED_PY" ] && [ -z "$STAGED_ARCH" ] && [ -z "$STAGED_TESTS" ]; then
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Test-sludge guard: reject narrating "Should ..." docstrings, redundant
# "Tests for ..." class docstrings, and ceremonial AAA comments in staged
# test files. See scripts/strip_test_sludge.py for the full pattern list.
if [ -n "$STAGED_TESTS" ]; then
    echo "pre-commit: running test-sludge check..."
    # shellcheck disable=SC2086
    if ! make test-sludge-check FILES="$STAGED_TESTS"; then
        exit 1
    fi
    echo "pre-commit: test-sludge OK"
fi

if [ -n "$STAGED_PY" ]; then
    echo "pre-commit: running make lint-check..."
    if ! make lint-check; then
        echo ""
        echo "pre-commit: lint-check failed; attempting self-repair with 'make lint-fix'..."
        if make lint-fix && make lint-check; then
            printf '%s\n' "$STAGED_PY" | xargs -I {} git add "{}"
            echo "pre-commit: self-repair succeeded and staged files were refreshed."
        else
            echo "Auto-repair failed. Run 'make lint-fix' and re-stage files."
            exit 1
        fi
    fi

    echo "pre-commit: lint OK"
fi

# Arch-regen check — fail-fast with helpful message when generated docs are stale.
# Reuses the existing `make arch-check` target (does not auto-stage).
if [ -n "$STAGED_ARCH" ]; then
    echo "pre-commit: running make arch-check..."
    if ! make arch-check >/tmp/hydraflow-arch-check.out 2>&1; then
        echo "❌ docs/arch/generated/ is out of sync with source." >&2
        echo "" >&2
        echo "Run:" >&2
        echo "  make arch-regen && git add docs/arch/" >&2
        echo "" >&2
        echo "First 20 lines of arch-check output:" >&2
        head -20 /tmp/hydraflow-arch-check.out >&2
        exit 1
    fi
    echo "pre-commit: arch-check OK"
fi
